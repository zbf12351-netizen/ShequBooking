/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-secondary {
  background-color: #ffffff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
}

/* 输入框样式 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #4CAF50;
  background-color: #ffffff;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-success {
  background-color: #e8f5e9;
  color: #4CAF50;
}

.tag-warning {
  background-color: #fff3e0;
  color: #ff9800;
}

.tag-danger {
  background-color: #ffebee;
  color: #f44336;
}

.tag-info {
  background-color: #e3f2fd;
  color: #2196F3;
}

/* 列表项样式 */
.list-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.list-item-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #cccccc;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

