/* pages/feedback-list/feedback-list.wxss */
.feedback-list-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.feedback-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-tag {
  padding: 8rpx 16rpx;
  background-color: #e3f2fd;
  color: #2196F3;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-pending { background-color: #fff3e0; color: #ff9800; }
.tag-replied { background-color: #e8f5e9; color: #4CAF50; }
.tag-closed { background-color: #f5f5f5; color: #999999; }

.feedback-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
  margin-bottom: 16rpx;
}

.feedback-reply {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.reply-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.reply-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
  margin-bottom: 8rpx;
}

.reply-time {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.feedback-time {
  font-size: 24rpx;
  color: #999999;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 64rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 16rpx rgba(76, 175, 80, 0.4);
}

