/* pages/notification-list/notification-list.wxss */
.notification-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.refresh-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  background-color: #e3f2fd;
  color: #1976d2;
  font-size: 28rpx;
}

.refresh-icon {
  margin-right: 10rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.unread-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff3cd;
  color: #856404;
  font-size: 28rpx;
}

.mark-all {
  color: #007bff;
}

.notification-list {
  padding: 20rpx;
}

.notification-item {
  position: relative;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.notification-item.unread {
  border-left: 8rpx solid #4CAF50;
}

.notification-item.read {
  opacity: 0.7;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.type-booking {
  background-color: #e3f2fd;
  color: #1976d2;
}

.type-audit {
  background-color: #fff3e0;
  color: #f57c00;
}

.type-system {
  background-color: #f5f5f5;
  color: #666666;
}

.type-reminder {
  background-color: #fce4ec;
  color: #c2185b;
}

.time {
  font-size: 24rpx;
  color: #999999;
}

.item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.item-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.unread-dot {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #f44336;
  border-radius: 50%;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}
