/* pages/booking-detail/booking-detail.wxss */
.detail-container {
  padding: 20rpx;
}

.detail-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
}

.status-tag {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.tag-draft { background-color: #e0e0e0; color: #666666; }
.tag-pending { background-color: #fff3e0; color: #ff9800; }
.tag-approved { background-color: #e8f5e9; color: #4CAF50; }
.tag-rejected { background-color: #ffebee; color: #f44336; }
.tag-cancelled { background-color: #f5f5f5; color: #999999; }
.tag-completed { background-color: #e3f2fd; color: #2196F3; }

.detail-item {
  display: flex;
  margin-bottom: 24rpx;
  line-height: 1.8;
}

.label {
  font-size: 28rpx;
  color: #666666;
  min-width: 160rpx;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.action-section {
  margin-top: 30rpx;
  text-align: center;
}

.checkin-btn {
  background: #4CAF50;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  width: 80%;
}

.checkin-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.review-btn {
  background: #2196F3;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  width: 80%;
}

.reviewed-hint {
  color: #4CAF50;
  font-size: 28rpx;
}

.checkin-info {
  margin-top: 16rpx;
}

.location-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ff9800;
}

.location-hint.success {
  background: #e8f5e9;
  color: #4CAF50;
}

.location-icon {
  font-size: 28rpx;
}

.location-text {
  flex: 1;
}
