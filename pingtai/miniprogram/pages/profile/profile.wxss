/* pages/profile/profile.wxss */
.profile-container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 未登录状态样式 */
.guest-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.guest-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  margin-bottom: 32rpx;
}

.guest-title {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.guest-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  margin-bottom: 48rpx;
}

.guest-buttons {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.btn-primary {
  background-color: #ffffff;
  color: #667eea;
  border: none;
  padding: 24rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}

.btn-secondary {
  background-color: transparent;
  color: #ffffff;
  border: 2rpx solid #ffffff;
  padding: 24rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}

.user-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  margin-right: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.role-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 24rpx;
  align-self: flex-start;
}

.menu-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #f44336;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #999999;
}

.btn-logout {
  background-color: #ffffff;
  color: #f44336;
  border-radius: 12rpx;
  padding: 32rpx;
  font-size: 32rpx;
  border: 2rpx solid #f44336;
}

