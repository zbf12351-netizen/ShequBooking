/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 40rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo-text {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 20rpx;
  height: 104rpx;
  line-height: 104rpx;
  padding: 0 32rpx;
  font-size: 34rpx;
  border: 2rpx solid transparent;
  width: 100%;
  box-sizing: border-box;
  color: #333333;
}

.btn-login {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 40rpx;
  border: none;
}

.register-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #666666;
}

.link {
  color: #667eea;
  font-weight: 500;
  margin-left: 8rpx;
}

/* 微信登录样式 */
.wechat-login-section {
  margin-top: 48rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.line {
  flex: 1;
  height: 1rpx;
  background-color: #e0e0e0;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #999999;
}

.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}
