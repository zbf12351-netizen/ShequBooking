/* pages/admin/facilities/facilities.wxss */
.facilities-container {
  padding: 20rpx;
}

.category-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
  transition: all 0.2s;
}

.tab-item.active {
  background: #4CAF50;
  color: #fff;
  border-color: #4CAF50;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.label {
  display: block;
  color: #666;
  margin-bottom: 6rpx;
  font-size: 26rpx;
}

.input, .textarea, .picker {
  border: 1px solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.textarea {
  min-height: 120rpx;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.btn {
  flex: 1;
}

.primary {
  background: #4CAF50;
  color: #fff;
  border: none;
}

.plain {
  border: 1px solid #4CAF50;
  color: #4CAF50;
  background: #fff;
}

.danger {
  border: 1px solid #f44336;
  color: #f44336;
  background: #fff;
}

.facility-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.facility-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1px solid #f2f2f2;
}

.facility-main {
  flex: 1;
}

.facility-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.facility-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 6rpx;
  margin-bottom: 6rpx;
}

.tag {
  font-size: 24rpx;
  color: #4CAF50;
  background: #e8f5e9;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
}

.status {
  font-size: 24rpx;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
}

.status.active {
  color: #4CAF50;
  background: #e8f5e9;
}

.status.disabled {
  color: #f44336;
  background: #ffebee;
}

.facility-location {
  font-size: 24rpx;
  color: #666;
}

.image-upload {
  display: flex;
  align-items: center;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.image-add .icon {
  font-size: 60rpx;
  line-height: 1;
}

.image-add .text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-preview image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background: #f44336;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.facility-actions {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-left: 12rpx;
}

.empty {
  text-align: center;
  color: #999;
  padding: 20rpx 0;
}

.load-more, .loading, .load-complete {
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.load-more {
  color: #4CAF50;
}

.form-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1px solid #f2f2f2;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #4CAF50;
}

.location-tip {
  display: block;
  font-size: 22rpx;
  color: #ff9800;
  margin-top: 8rpx;
}

