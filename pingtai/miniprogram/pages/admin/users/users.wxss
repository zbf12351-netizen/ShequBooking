/* pages/admin/users/users.wxss */
.users-container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.label {
  display: block;
  color: #666;
  margin-bottom: 6rpx;
  font-size: 26rpx;
}

.input {
  border: 1px solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.btn {
  margin-top: 8rpx;
}

.primary {
  background: #4CAF50;
  color: #fff;
  border: none;
}

.plain {
  border: 1px solid #4CAF50;
  color: #4CAF50;
  background: #fff;
}

.filter {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-item {
  padding: 8rpx 14rpx;
  border: 1px solid #e0e0e0;
  border-radius: 20rpx;
  color: #666;
  font-size: 26rpx;
}

.filter-item.active {
  border-color: #4CAF50;
  color: #4CAF50;
  background: #e8f5e9;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1px solid #f2f2f2;
}

.user-main {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.role-tag {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #666;
}

.user-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status {
  font-size: 24rpx;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
}

.status.active {
  background: #e8f5e9;
  color: #4CAF50;
}

.status.disabled {
  background: #ffebee;
  color: #f44336;
}

.empty {
  text-align: center;
  color: #999;
  padding: 20rpx 0;
}

.role-selector {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.role-option {
  padding: 16rpx 32rpx;
  border: 1px solid #e0e0e0;
  border-radius: 8rpx;
  color: #666;
  font-size: 28rpx;
}

.role-option.active {
  border-color: #4CAF50;
  color: #4CAF50;
  background: #e8f5e9;
}

