/* pages/admin/export/export.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 报表类型列表 */
.report-list {
  margin-top: 10rpx;
}

.report-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.report-item:last-child {
  border-bottom: none;
}

.report-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f0f7ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.report-info {
  flex: 1;
}

.report-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.report-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.report-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 时间筛选 */
.period-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.period-btn {
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 26rpx;
}

.period-btn.active {
  background-color: #1890ff;
  color: #fff;
}

/* 导出按钮 */
.btn-export {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

/* 预览表格 */
.preview-table {
  white-space: nowrap;
  overflow: hidden;
}

.table-header {
  display: flex;
  background-color: #f5f5f5;
  padding: 16rpx 0;
}

.table-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.table-cell {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  text-align: center;
  min-width: 120rpx;
  padding: 0 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.preview-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
