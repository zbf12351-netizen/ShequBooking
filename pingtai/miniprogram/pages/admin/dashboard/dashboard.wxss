/* pages/admin/dashboard/dashboard.wxss */
.dashboard-container {
  padding: 20rpx;
  min-height: 100vh;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.menu-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333333;
}

.btn-back {
  background-color: #f44336;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  font-size: 32rpx;
  border: none;
}

