/* pages/admin/notifications/notifications.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.form-group {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  background-color: #4CAF50;
  color: #ffffff;
  text-align: center;
  padding: 28rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 20rpx;
}

.notification-list {
  margin-top: 20rpx;
}

.notification-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.notification-item:last-child {
  border-bottom: none;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.notification-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.notification-time {
  font-size: 24rpx;
  color: #999999;
}

.notification-type {
  margin-bottom: 12rpx;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.type-tag.system {
  background-color: #e3f2fd;
  color: #2196F3;
}

.type-tag.booking {
  background-color: #fff3e0;
  color: #ff9800;
}

.type-tag.warning {
  background-color: #ffebee;
  color: #f44336;
}

.notification-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}
