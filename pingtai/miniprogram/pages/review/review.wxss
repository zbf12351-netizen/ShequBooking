/* pages/review/review.wxss */
.review-container {
  padding: 20rpx;
}

.facility-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.facility-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.booking-info {
  font-size: 28rpx;
  color: #666;
}

.rating-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.rating-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.stars {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.star-icon {
  font-size: 60rpx;
  color: #ddd;
  transition: all 0.2s;
}

.star-icon.active {
  color: #ffc107;
}

.rating-text {
  font-size: 28rpx;
  color: #666;
}

.comment-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.comment-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.comment-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.submit-btn {
  background: #007aff;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  margin-top: 40rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}
