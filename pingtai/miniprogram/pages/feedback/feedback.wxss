/* pages/feedback/feedback.wxss */
.feedback-container {
  padding: 20rpx;
}

.form-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.btn-submit {
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 40rpx;
  border: none;
}

