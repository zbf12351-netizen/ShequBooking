/* pages/notification-detail/notification-detail.wxss */
.detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.detail-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.type-badge {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.type-booking {
  background-color: #e3f2fd;
  color: #1976d2;
}

.type-audit {
  background-color: #fff3e0;
  color: #f57c00;
}

.type-system {
  background-color: #f5f5f5;
  color: #666666;
}

.type-reminder {
  background-color: #fce4ec;
  color: #c2185b;
}

.time {
  font-size: 26rpx;
  color: #999999;
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.card-content {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.8;
}
