<!--pages/favorite-list/favorite-list.wxml-->
<view class="favorite-container">
  <view class="favorite-list">
    <view
      class="favorite-card"
      wx:for="{{favorites}}"
      wx:key="facility_id"
      data-id="{{item.facility_id}}"
      data-index="{{index}}"
      bindtap="goToDetail"
    >
      <!-- 左侧主要信息区 -->
      <view class="left-section">
        <!-- 标题 -->
        <text class="card-title">{{item.name}}</text>
        
        <!-- 标签行：两个标签完全一致 -->
        <view class="tag-row">
          <text class="tag">{{item.category}}</text>
          <text class="tag">{{item.status === 1 ? '可预约' : '已停用'}}</text>
        </view>
        
        <!-- 描述 -->
        <text class="card-desc">{{item.description}}</text>
      </view>
      
      <!-- 右上角收藏区 -->
      <view class="favorite-section">
        <view class="favorite-box">
          <text class="heart-icon">♥</text>
          <text class="favorite-text">已收藏</text>
        </view>
      </view>
      
      <!-- 底部地址区 -->
      <view class="divider"></view>
      <view class="bottom-section">
        <text class="location-icon">📍</text>
        <text class="location-text">{{item.location}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{favorites.length === 0 && !loading}}">
    <text class="empty-icon">♡</text>
    <text class="empty-text">暂无收藏</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="load-more" wx:if="{{hasMore && !loading}}" bindtap="loadMore">
    <text>加载更多</text>
  </view>
</view>
