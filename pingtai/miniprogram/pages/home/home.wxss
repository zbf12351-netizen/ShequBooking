/* pages/home/home.wxss */
.home-container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 欢迎区样式 */
.welcome-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.welcome-text .greeting {
  display: block;
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.welcome-text .desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 未登录引导样式 */
.welcome-guest {
  flex-wrap: wrap;
}

.welcome-guest .welcome-text {
  flex: 1;
  min-width: 300rpx;
}

.auth-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
}

.btn-login,
.btn-register {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-login {
  background-color: #ffffff;
  color: #667eea;
  border: none;
}

.btn-register {
  background-color: transparent;
  color: #ffffff;
  border: 2rpx solid #ffffff;
}

/* 公告栏样式 */
.announcement-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.announcement-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.announcement-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.announcement-badge {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.announcement-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.announcement-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.announcement-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

/* 快捷功能 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #999999;
}

.facility-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.facility-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.facility-image-placeholder {
  width: 200rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.facility-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.facility-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.facility-location {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.facility-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-info {
  background-color: #e3f2fd;
  color: #2196f3;
}

.facility-rating {
  font-size: 24rpx;
  color: #FF9800;
}

.facility-fav {
  font-size: 24rpx;
  color: #ff9800;
}

.popular-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.popular-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.popular-item:last-child {
  border-bottom: none;
}

.popular-rank {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.popular-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.popular-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.popular-count {
  font-size: 24rpx;
  color: #999999;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 未登录提示卡片 */
.login-prompt-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.prompt-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.prompt-title {
  display: block;
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.prompt-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}