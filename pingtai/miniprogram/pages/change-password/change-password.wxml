<!--pages/change-password/change-password.wxml-->
<view class="container">
  <form bindsubmit="submitForm">
    <view class="form-group">
      <text class="label">旧密码</text>
      <input 
        class="input" 
        name="old_password" 
        type="password" 
        password="{{true}}" 
        placeholder="请输入旧密码"
        value="{{oldPassword}}"
      />
    </view>

    <view class="form-group">
      <text class="label">新密码</text>
      <input 
        class="input" 
        name="new_password" 
        type="password" 
        password="{{true}}" 
        placeholder="请输入新密码（至少6位）"
        value="{{newPassword}}"
      />
    </view>

    <view class="form-group">
      <text class="label">确认密码</text>
      <input 
        class="input" 
        name="confirm_password" 
        type="password" 
        password="{{true}}" 
        placeholder="请再次输入新密码"
        value="{{confirmPassword}}"
      />
    </view>

    <button class="btn-submit" form-type="submit" loading="{{loading}}">
      确认修改
    </button>
  </form>
</view>
