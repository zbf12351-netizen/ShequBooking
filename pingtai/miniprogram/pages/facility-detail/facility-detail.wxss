/* pages/facility-detail/facility-detail.wxss */
.detail-container {
  padding-bottom: 120rpx;
}

.facility-header-image {
  width: 100%;
  height: 400rpx;
}

.facility-header-image image {
  width: 100%;
  height: 100%;
}

.facility-header-placeholder {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.facility-category-large {
  font-size: 80rpx;
  color: #ffffff;
  font-weight: bold;
}

.info-card {
  background-color: #ffffff;
  padding: 32rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.facility-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.facility-name {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
}

.facility-status {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.facility-status.available {
  background-color: #e8f5e9;
  color: #4CAF50;
}

.facility-status.unavailable {
  background-color: #ffebee;
  color: #f44336;
}

.facility-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.rating {
  font-size: 26rpx;
  color: #FF9800;
}

.booking-count {
  font-size: 26rpx;
  color: #f44336;
}

.fav-count {
  font-size: 26rpx;
  color: #ff9800;
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  min-width: 140rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx 32rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 20rpx;
}

.btn-booking {
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  flex: 1;
}

.btn-favorite {
  background-color: #fff7e6;
  color: #ff9800;
  border-radius: 12rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #ffe0b2;
  flex: 1;
}

/* 已收藏状态 */
.btn-favorite-active {
  background-color: #fff3e0;
  color: #f57c00;
  border-color: #ffb74d;
}

.btn-favorite-disabled {
  background-color: #f5f5f5;
  color: #999999;
  border-color: #e0e0e0;
}

/* 评价列表样式 */
.reviews-section {
  background-color: #ffffff;
  padding: 32rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-subtitle {
  font-size: 28rpx;
  color: #ff9800;
}

.review-list {
  margin-bottom: 20rpx;
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.review-time {
  font-size: 24rpx;
  color: #999999;
}

.review-rating {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.review-rating text {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.review-rating text:last-child {
  margin-right: 0;
}

.review-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #4CAF50;
  font-size: 28rpx;
}
