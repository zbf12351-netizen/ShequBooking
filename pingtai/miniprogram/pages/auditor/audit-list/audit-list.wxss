/* pages/auditor/audit-list/audit-list.wxss */
.audit-list-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.audit-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.phone {
  font-size: 26rpx;
  color: #999999;
}

.booking-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.facility-name {
  font-size: 28rpx;
  color: #333333;
}

.booking-time {
  font-size: 26rpx;
  color: #666666;
}

.purpose {
  font-size: 26rpx;
  color: #666666;
}

.audit-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.btn-reject {
  background-color: #f44336;
  color: #ffffff;
  border: none;
}

.btn-approve {
  background-color: #4CAF50;
  color: #ffffff;
  border: none;
}

.nav-buttons {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  gap: 20rpx;
}

.nav-buttons button {
  flex: 1;
  background-color: #2196F3;
  color: #ffffff;
  border-radius: 12rpx;
}

.nav-buttons .btn-logout {
  background-color: #f44336;
}
