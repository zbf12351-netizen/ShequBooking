/* pages/register/register.wxss */
.register-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 60rpx 40rpx;
}

.register-header {
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

.register-form {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 16rpx;
  height: 100rpx;
  line-height: 100rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  border: 2rpx solid transparent;
  width: 100%;
  box-sizing: border-box;
  color: #333333;
}

.btn-register {
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 40rpx;
  border: none;
}

.login-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #666666;
}

.link {
  color: #4CAF50;
  font-weight: 500;
  margin-left: 8rpx;
}

